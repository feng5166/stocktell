# 复制为 .env.local。都不填也能跑(回退本地 JSON + 模板生成,无登录/无飞书)。

# Vercel Postgres(底层 Neon):在 Vercel 项目 Storage 里创建后会自动注入。
# 本地用 `vercel env pull .env.local` 一键拉取。
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# LLM(OpenAI 兼容网关,默认 modelverse.cn)。换模型/换厂商只改这三个。
LLM_BASE_URL=https://api.modelverse.cn/v1
LLM_API_KEY=
LLM_MODEL=glm-5.2

# NextAuth 登录
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=          # openssl rand -base64 32
# Google 登录(可选):填了并把 NEXT_PUBLIC_GOOGLE_AUTH=1 才启用
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_AUTH=

# 飞书新用户提醒(自建应用机器人;不填则跳过)
FEISHU_BOT_APP_ID=
FEISHU_BOT_APP_SECRET=
FEISHU_USER_OPEN_ID=

# 博查 Web Search(为「为什么动」提供真实新闻检索)。约 ¥0.036/次。
# 配了就自动启用检索增强(搜真实新闻→只基于材料总结,带来源链接),没配则「为什么动」保持关闭。
BOCHA_API_KEY=
# 无博查 key 时,可改用「模型自带联网」的旧路径(默认关):置 1 且 LLM_* 指向能联网的模型
WHY_ENABLED=
WHY_LLM_MODEL=
