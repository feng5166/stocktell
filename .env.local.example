# 复制为 .env.local。都不填也能跑(回退本地 JSON + 模板生成)。

# Vercel Postgres(底层 Neon):在 Vercel 项目 Storage 里创建后会自动注入这些变量。
# 本地开发用 `vercel env pull .env.local` 一键拉取,或手动粘贴。
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# LLM(OpenAI 兼容网关,默认 modelverse.cn)。换模型/换厂商只改这三个变量。
# 不填 LLM_API_KEY 则简报用模板生成。
LLM_BASE_URL=https://api.modelverse.cn/v1
LLM_API_KEY=
LLM_MODEL=glm-5.2
