// StockTell 数据库 schema(Prisma)
// 底层 Postgres = Vercel Postgres(Neon)。Vercel 会把连接串自动注入项目环境变量。
// POSTGRES_PRISMA_URL = 连接池(pgbouncer,运行时用);
// POSTGRES_URL_NON_POOLING = 直连(给 prisma migrate / db push 用)。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("push_subscriptions")
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  passwordHash String?  @map("password_hash")
  nickname     String?
  avatar       String?
  weixinOpenId String?  @unique @map("weixin_open_id")
  // 扫码了但还没发消息激活的时间戳;激活/解绑时清空。用于站内"还差一步"提醒 + 后台统计。
  weixinPendingScanAt DateTime? @map("weixin_pending_scan_at")
  // 退订每日邮件推送:邮件里"取消推送"按钮(带签名)点击后置 true,盘前 digest 跳过。
  digestOptOut Boolean  @default(false) @map("digest_opt_out")
  // 关闭盘中异动提醒(默认开);仅对已绑微信用户有意义。
  intradayOptOut Boolean @default(false) @map("intraday_opt_out")
  // 关闭雷区提醒(解禁/增减持/质押/ST,默认开)
  riskOptOut   Boolean  @default(false) @map("risk_opt_out")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("users")
}

// 雷区提醒去重:同一用户·同一事件(eventKey)只推一次。
model EventAlert {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  eventKey  String   @map("event_key") // 类型:code:关键日 等
  date      String // 推送日 YYYY-MM-DD(北京)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, eventKey])
  @@index([userId])
  @@map("event_alert")
}

// 盘中异动提醒去重:同一用户·同一票·同一天最多提醒一次。
model IntradayAlert {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  code      String
  date      String // YYYY-MM-DD(北京)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, code, date])
  @@index([userId, date])
  @@map("intraday_alert")
}

model WeixinBindToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("weixin_bind_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("password_reset_tokens")
}

model BriefingItem {
  id            String   @id @default(uuid())
  date          String // YYYY-MM-DD
  impact        String // 高 / 中 / 低
  title         String
  triggerCode   String?  @map("trigger_code")
  triggerName   String?  @map("trigger_name")
  triggerChange Float?   @map("trigger_change") // 触发美股当时涨跌%,记账判方向用
  beneficiaries Json     @default("[]")
  retailTake    String   @map("retail_take")
  sourceUrl     String?  @map("source_url")
  status        String   @default("draft") // draft / published
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([date, status])
  @@map("briefing_items")
}

// 简报记账:每条简报的受益股,在简报当日收盘后回填实际表现,等用户查账。
// 判命中规则透明:触发美股涨→期待A股涨,跌→期待A股跌;同向且|涨跌|≥阈值记 hit。
model BriefingOutcome {
  id          String   @id @default(cuid())
  briefingId  String   @map("briefing_id")
  date        String // 简报日 YYYY-MM-DD
  title       String // 冗余简报标题,查账页直接展示
  impact      String // 高 / 中 / 低
  code        String // 受益 A 股代码
  name        String // 受益 A 股名称
  expected    String // "涨" / "跌",来自触发美股方向
  change      Float? // 评估日(简报当日收盘)A股实际涨跌%
  hit         Boolean? // 是否跟上;null = 当时取不到行情
  isBacktest  Boolean  @default(false) @map("is_backtest") // true=历史回测(明牌),非实盘喊单
  evaluatedAt DateTime @default(now()) @map("evaluated_at")

  @@unique([briefingId, code])
  @@index([date])
  @@index([isBacktest])
  // 战绩页分页/统计的主查询:where isBacktest + orderBy date —— 复合索引免全表扫
  @@index([isBacktest, date])
  @@map("briefing_outcomes")
}

// 我的自选/持仓:只存 code(成本/持股二期再说)。游客走 localStorage,登录用户落这张表。
model Watchlist {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  code      String // 关联 STOCK_MAP 的 code
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, code])
  @@index([userId])
  @@map("watchlist")
}

// 「为什么动」全局缓存:按 code+date 存检索+总结结果(含来源摘要),避免重复打博查/LLM。
// reason 为 null 也缓存(带 updatedAt 控制重试),避免对"确实没新闻"的标的反复检索。
model WhyCache {
  code          String
  date          String
  reason        String?
  asOf          String?  @map("as_of")
  sourceUrl     String?  @map("source_url")
  sourceTitle   String?  @map("source_title")
  sourceSummary String?  @map("source_summary")
  sourceSite    String?  @map("source_site")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@id([code, date])
  @@map("why_cache")
}

// 「散户怎么想·详细解读」缓存:按简报条目 id 存一次,点击即取/生成,避免重复打 LLM。
model DeepAnalysisCache {
  briefingId String   @id @map("briefing_id")
  content    String
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("deep_analysis_cache")
}

// 个性化早报每日缓存:key = 当天日期 + 自选组合 hash;同自选同一天只生成一次。
model MorningBriefCache {
  key       String   @id
  brief     String
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("morning_brief_cache")
}

// 其他产业链「我想要」投票:收集用户最想先看哪条链(去重:一人一链一票)。
model ChainInterest {
  id        String   @id @default(cuid())
  chain     String // 产业链 key
  voter     String // 投票人(登录 userId 或游客 clientId)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([chain, voter])
  @@index([chain])
  @@map("chain_interest")
}

// 行情缓存:行情接口成功时写最新一份,断连/休市时读它(标注"截至几号"),避免给用户空白。
model QuotesCache {
  id        String   @id @default("latest")
  data      Json // Record<code, {price,change,asOf}>
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("quotes_cache")
}

// 用户反馈(问题/建议/其他)。游客也可提,userId/email 可空。
model Feedback {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  email     String?
  category  String   @default("其他")
  content   String
  path      String? // 提交时所在页面
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("feedback")
}
